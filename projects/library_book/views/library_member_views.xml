<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_member_tree" model="ir.ui.view">
        <field name="name">library.member.tree</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="membership_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'expired'"/>
            </tree>
        </field>
    </record>

    <record id="view_member_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_reactivate" string="Reactivate"
                            type="object" states="expired,suspended"
                            class="btn-success"/>
                    <button name="action_suspend" string="Suspend"
                            type="object" states="active"
                            class="btn-warning"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="membership_date"/>
                            <field name="expiry_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Current Borrows">
                            <field name="current_borrow_ids">
                                <tree>
                                    <field name="book_id"/>
                                    <field name="borrow_date"/>
                                    <field name="expected_return_date"/>
                                </tree>
                            </field>
                        </page>
                        <page string="History">
                            <field name="borrow_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
