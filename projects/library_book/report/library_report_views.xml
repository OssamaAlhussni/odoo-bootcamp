<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_book" model="ir.actions.report">
        <field name="name">Book Report</field>
        <field name="model">library.book</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">library_book.report_book</field>
        <field name="report_file">library_book.report_book</field>
        <field name="print_report_name">'Book - %s' % object.name</field>
        <field name="binding_model_id" ref="model_library_book"/>
        <field name="binding_view_types">list</field>
    </record>

    <template id="report_book">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 t-field="doc.name"/>
                    <p><strong>Author:</strong> <span t-field="doc.author"/></p>
                    <p><strong>ISBN:</strong> <span t-field="doc.isbn"/></p>
                    <p><strong>Publisher:</strong> <span t-field="doc.publisher"/></p>
                    <p><strong>Category:</strong> <span t-field="doc.category_id.name"/></p>
                    <p><strong>Status:</strong> <span t-field="doc.state"/></p>
                    <p><strong>Price:</strong>
                        <span t-field="doc.price" t-options='{"widget": "monetary"}'/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>
