<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_property_view_form_inherit" model="ir.ui.view">
        <field name="name">estate.property.form.inherit.account</field>
        <field name="model">estate.property</field>
        <field name="inherit_id" ref="estate.estate_property_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='selling_price']" position="after">
                <field name="journal_id"/>
            </xpath>
        </field>
    </record>
</odoo>
