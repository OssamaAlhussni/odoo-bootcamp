<?xml version="1.0" encoding="utf-8"?>
<!--
    ESTATE PROPERTY VIEWS
    =====================
    This file defines how estate.property records are displayed.
    
    View types:
    - tree  → table/list view (multiple records)
    - form  → single record detail (create/edit)
    - kanban → card-based layout
    - search → filters and grouping
    - graph, pivot, calendar, cohort, gantt, map, activity, dashboard
    
    The act_window record ties everything together — it tells Odoo
    which views to show and in what order when the menu item is clicked.
-->
<odoo>
    <!-- ACT WINDOW — this is what the menu item opens -->
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>           <!-- Tab title -->
        <field name="res_model">estate.property</field> <!-- Which model -->
        <field name="view_mode">kanban,tree,form</field> <!-- Available views (order matters) -->
        <field name="context">{'search_default_state': 'new'}</field> <!-- Default filter -->
    </record>

    <!-- TREE VIEW — table/list of properties -->
    <record id="estate_property_view_tree" model="ir.ui.view">
        <field name="name">estate.property.tree</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <!-- tree = table view. Each child field = one column -->
            <tree>
                <field name="name" string="Title"/>
                <field name="property_type_id" string="Type"/>
                <field name="expected_price" string="Expected Price" widget="monetary"/>
                <field name="bedrooms" string="Bedrooms"/>
                <field name="living_area" string="Living Area"/>
                <!-- decoration-* = conditional row coloring -->
                <field name="state" string="Status" widget="badge"
                       decoration-success="state == 'sold'"
                       decoration-warning="state == 'offer_received'"
                       decoration-info="state == 'offer_accepted'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW — edit/create a single property -->
    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <!-- form = single record editor -->
            <form>
                <!-- HEADER: buttons and status bar (always visible) -->
                <header>
                    <!-- type="object" = calls a Python method on the model -->
                    <!-- states="offer_accepted" = only visible in that state -->
                    <button name="action_sell" string="Sold" type="object"
                            class="btn-primary" states="offer_accepted"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            states="new,offer_received,offer_accepted"/>
                    <!-- statusbar = workflow progress indicator -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,offer_received,offer_accepted,sold"/>
                </header>
                
                <!-- SHEET: main content area (white background card) -->
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Property title..."/></h1>
                    </div>
                    
                    <!-- group = two-column layout (each <group> inside = one column) -->
                    <group>
                        <group string="Details">
                            <field name="property_type_id"/>
                            <!-- widget="many2many_tags" = show tags as colored badges -->
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="bedrooms"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                        </group>
                        <group string="Pricing">
                            <field name="expected_price" widget="monetary"/>
                            <field name="selling_price" widget="monetary"/>
                            <field name="best_price" widget="monetary"/>
                            <field name="date_availability"/>
                        </group>
                    </group>
                    
                    <!-- notebook = tabbed interface -->
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Add a description..."/>
                        </page>
                        <page string="Offers">
                            <!-- 
                                Inline tree view for One2many field.
                                editable="bottom" = add new rows at the bottom
                            -->
                            <field name="offer_ids">
                                <tree editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="price" widget="monetary"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'accepted'"
                                           decoration-danger="status == 'refused'"/>
                                    <field name="validity"/>
                                    <field name="date_deadline"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Garden">
                            <group>
                                <field name="garden"/>
                                <!-- attrs = dynamic visibility (only show if garden=True) -->
                                <field name="garden_area"
                                       attrs="{'invisible': [('garden', '=', False)]}"/>
                                <field name="garden_orientation"
                                       attrs="{'invisible': [('garden', '=', False)]}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW — card-based visual layout -->
    <record id="estate_property_view_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <!-- kanban = cards. Uses QWeb templates for layout -->
            <kanban>
                <!-- Fields that kanban needs access to -->
                <field name="name"/>
                <field name="expected_price"/>
                <field name="state"/>
                <field name="bedrooms"/>
                <templates>
                    <!-- t-name="kanban-box" = template for each card -->
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div class="text-muted">
                                    <field name="expected_price" widget="monetary"/>
                                    - <field name="bedrooms"/> bedrooms
                                </div>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'sold'"
                                       decoration-warning="state == 'offer_received'"
                                       decoration-info="state == 'offer_accepted'"
                                       decoration-danger="state == 'cancelled'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW — filters, favorites, grouping -->
    <record id="estate_property_view_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <!-- Quick search fields -->
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="tag_ids"/>
                
                <!-- Predefined filters -->
                <filter name="state_new" string="New" domain="[('state','=','new')]"/>
                <filter name="state_sold" string="Sold" domain="[('state','=','sold')]"/>
                
                <separator/>
                
                <!-- Group by options (adds a column header to group records) -->
                <filter name="group_type" string="Type"
                        context="{'group_by': 'property_type_id'}"/>
                <filter name="group_state" string="Status"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
</odoo>
